# Copy to .env and fill in
DATABASE_URL=postgresql://boss:boss123@db:5432/bossjob

# Your deployed Llama endpoint (OpenAI-compatible)
LLAMA_BASE_URL=https://aisrv3.pinoyjobs.ph/api-llm/llma3.3
LLAMA_MODEL=RedHatAI/Llama-3.3-70B-Instruct-FP8-dynamic
LLAMA_API_KEY=your-api-key-here

# Embedding model (sentence-transformers, runs locally in backend)
EMBED_MODEL=all-MiniLM-L6-v2
